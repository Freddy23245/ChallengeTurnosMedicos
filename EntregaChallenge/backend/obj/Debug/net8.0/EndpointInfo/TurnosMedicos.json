  "components": {
    "schemas": {
      "ActualizarEstadoRequest": {
        "type": "object",
        "properties": {
          "estado": {
            "$ref": "#/components/schemas/EstadoTurno"
          }
        },
        "additionalProperties": false
      },
      "EstadoTurno": {
        "enum": [
          "Pendiente",
          "Confirmado",
          "Cancelado",
          "Atendido",
          "NoShow"
        ],
        "type": "string"
      },
      "Medico": {
        "required": [
          "especialidad",
          "nombreCompleto",
          "sucursalId"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "nombreCompleto": {
            "minLength": 1,
            "type": "string"
          },
          "especialidad": {
            "minLength": 1,
            "type": "string"
          },
          "sucursalId": {
            "type": "integer",
            "format": "int32"
          },
          "sucursal": {
            "$ref": "#/components/schemas/Sucursal"
          }
        },
        "additionalProperties": false
      },
      "Paciente": {
        "required": [
          "dni",
          "email",
          "nombreCompleto",
          "telefono"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "nombreCompleto": {
            "minLength": 1,
            "type": "string"
          },
          "dni": {
            "maxLength": 8,
            "minLength": 0,
            "pattern": "^\\d{8}$",
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "telefono": {
            "maxLength": 10,
            "minLength": 0,
            "pattern": "^\\d{10}$",
            "type": "string",
            "format": "tel"
          },
          "noShowCount": {
            "type": "integer",
            "format": "int32"
          },
          "bloqueado": {
            "type": "boolean"
          },
          "fechaBloqueo": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "isActive": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "Sucursal": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "nombre": {
            "type": "string",
            "nullable": true
          },
          "direccion": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Turno": {
        "required": [
          "fechaHora",
          "medicoId",
          "pacienteId"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "pacienteId": {
            "type": "integer",
            "format": "int32"
          },
          "paciente": {
            "$ref": "#/components/schemas/Paciente"
          },
          "medicoId": {
            "type": "integer",
            "format": "int32"
          },
          "medico": {
            "$ref": "#/components/schemas/Medico"
          },
          "fechaHora": {
            "type": "string",
            "format": "date-time"
          },
          "estado": {
            "$ref": "#/components/schemas/EstadoTurno"
          },
          "fechaCreacion": {
            "type": "string",
            "format": "date-time"
          },
          "motivo": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
